# .env
# CORE SYSTEM CONFIGURATION - PATHLESS

# -----------------------------------------------------------------------------
# DATABASE CONNECTION STRING
# -----------------------------------------------------------------------------
# Format PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA

# Gunakan baris ini jika Anda menggunakan PostgreSQL (Default Prisma Schema)
DATABASE_URL="postgresql://postgres:Muhammadrafli22@localhost:6666/pathless_db?schema=public"


# -----------------------------------------------------------------------------
# ALTERNATIF: MYSQL (Opsional)
# -----------------------------------------------------------------------------
# Jika Anda lebih memilih MySQL, pastikan Anda mengubah `provider = "postgresql"` 
# menjadi `provider = "mysql"` di dalam file `prisma/schema.prisma`.
# Lalu, matikan (comment) DATABASE_URL PostgreSQL di atas, dan nyalakan yang ini:

# DATABASE_URL="mysql://root:password123@localhost:3306/pathless_db"

NEXTAUTH_SECRET="kunci-rahasia-pathless-bebas-diisi-apa-saja"
NEXTAUTH_URL="http://localhost:3000"